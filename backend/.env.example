# Copy this file to .env and fill in real values. Never commit .env - it's gitignored.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (required) ---
# MongoDB Atlas connection string, or a local mongod instance.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/secureshare

# --- Auth (required) ---
# Any long random string. Rotate this and all existing JWTs/sessions become invalid.
JWT_SECRET=change_this_to_a_long_random_secret

# --- Cloudinary (required) ---
# File storage backend - https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Legacy RSA keypair (required only for encryptionVersion 1 / pre-Phase-1 files) ---
# Generate with: node generateKeys.js (writes public.pem/private.pem to backend/)
# Then paste their contents here, OR provide the *_BASE64 variants instead, OR leave both
# unset and place the .pem files at backend/keys/public.pem and backend/keys/private.pem.
# New (client-side E2E encrypted) uploads never use this - only legacy v1 files do.
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
# Alternative to the two above: base64-encode the whole PEM file contents.
# RSA_PUBLIC_KEY_BASE64=
# RSA_PRIVATE_KEY_BASE64=

# --- Phase 4: Malware scanning (both optional - the app degrades gracefully without them) ---
# Host/port of a running clamd daemon. If unreachable, ClamAV scan status reports "unavailable"
# and the rest of the threat pipeline (magic bytes, hashing, VirusTotal, risk engine) still runs.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# VirusTotal API v3 key (free tier: https://www.virustotal.com/gui/join-us). If unset, VirusTotal
# hash lookups are skipped entirely (scanStatus "skipped") with no error.
VIRUSTOTAL_API_KEY=
