# Copy this file to .env and fill in real values. Never commit .env - it's gitignored.

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (required) ---
# MongoDB Atlas connection string, or a local mongod instance.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/secureshare

# --- Auth (required) ---
# Any long random string. Rotate this and all existing JWTs/sessions become invalid.
JWT_SECRET=change_this_to_a_long_random_secret

# --- Cloudinary (required) ---
# File storage backend - https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Legacy RSA keypair (required only for encryptionVersion 1 / pre-Phase-1 files) ---
# Generate with: node generateKeys.js (writes public.pem/private.pem to backend/)
# Then paste their contents here, OR provide the *_BASE64 variants instead, OR leave both
# unset and place the .pem files at backend/keys/public.pem and backend/keys/private.pem.
# New (client-side E2E encrypted) uploads never use this - only legacy v1 files do.
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
# Alternative to the two above: base64-encode the whole PEM file contents.
# RSA_PUBLIC_KEY_BASE64=
# RSA_PRIVATE_KEY_BASE64=

# --- Phase 4: Malware scanning (both optional - the app degrades gracefully without them) ---
# Host/port of a running clamd daemon. If unreachable, ClamAV scan status reports "unavailable"
# and the rest of the threat pipeline (magic bytes, hashing, VirusTotal, risk engine) still runs.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# VirusTotal API v3 key (free tier: https://www.virustotal.com/gui/join-us). If unset, VirusTotal
# hash lookups are skipped entirely (scanStatus "skipped") with no error.
VIRUSTOTAL_API_KEY=

# --- Phase 7: Threat Intelligence (all optional - enrichment degrades gracefully without them) ---
# Reused for Phase 7's hash/domain/URL provider alongside Phase 4's hash-only lookup above.
# VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (free tier: https://www.abuseipdb.com/register). If unset, IP reputation
# lookups against AbuseIPDB are skipped.
ABUSEIPDB_API_KEY=

# AlienVault OTX API key (free: https://otx.alienvault.com). If unset, OTX pulse lookups are skipped.
OTX_API_KEY=

# URLHaus/OpenPhish/CIRCL require no API key and are enabled by default. Set to "false" to disable
# any of them explicitly (e.g. air-gapped/offline environments).
# THREAT_INTEL_ENABLE_URLHAUS=false
# THREAT_INTEL_ENABLE_OPENPHISH=false
# THREAT_INTEL_ENABLE_CIRCL=false

# --- Phase 9: Identity & Access Management / Passkeys (WebAuthn is inherently origin-bound - set
# these correctly for your real domain in production; the defaults only work for local dev) ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SecureShare
WEBAUTHN_ORIGIN=http://localhost:3000

# --- Phase 11: Cloud Security Posture Management / Attack Surface Management (all optional) ---
# Base URL the attack-surface scanner self-probes (robots.txt, /admin, /metrics, etc). Defaults to
# http://localhost:${PORT} - only override if the app is reachable at a different local address.
APP_BASE_URL=http://localhost:5000

# Comma-separated list of production HTTPS domains to monitor for certificate expiry/weak TLS.
# WEBAUTHN_ORIGIN's hostname is monitored automatically when it's HTTPS - this is for any others.
CLOUD_MONITORED_DOMAINS=

# --- Phase 12: Enterprise DevSecOps / Software Supply Chain Security (all optional) ---
# A GitHub personal access token with `actions:read` scope, and the "owner/repo" it applies to.
# If unset, CI/CD pipeline status is only detected from local repo config (.github/workflows
# presence), never fetched live - the pipeline monitor degrades gracefully without these.
GITHUB_TOKEN=
GITHUB_REPO=

# --- Phase 13: Production Hardening & Cloud Platform Operations (all optional - the platform
# degrades gracefully without Redis: rate limiting/queue/health checks fall back to in-memory/
# in-process equivalents). Deploys to Vercel (frontend) + Render (backend + ClamAV) + MongoDB
# Atlas + Redis Cloud + Cloudinary - no local infrastructure is required. ---
# Redis Cloud connection string (redis://default:<password>@<host>:<port>). Powers caching,
# rate-limit storage, session cache, and the BullMQ background job queue.
REDIS_URL=

# The deployed Vercel frontend URL, probed by the Platform Health Engine's "Frontend API" check.
# Falls back to WEBAUTHN_ORIGIN if unset.
FRONTEND_URL=https://your-frontend.vercel.app

# Structured logging verbosity: error | warn | info | debug.
LOG_LEVEL=info
